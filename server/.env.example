# Copy to .env and fill in. Never commit the real .env.

# For the Gemini/Imagen proxy (npm run gemini) — get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# For the OpenAI proxy (npm start).
OPENAI_API_KEY=sk-...

# Port the proxy listens on (default 8080).
PORT=8080

# Allowed CORS origins (comma-separated). Use the Flutter app's origin in prod,
# e.g. https://lingua.yourdomain.com . "*" allows any origin (dev only).
CORS_ORIGIN=*

# Rate limiting for POST /image.
RATE_WINDOW_MS=900000   # window length in ms (default 15 min)
RATE_MAX=30             # max requests per IP per window

# Number of proxy hops to trust for the real client IP (1 behind a single LB).
TRUST_PROXY=1
